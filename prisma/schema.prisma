// Dispatch CRM — Complete Prisma Schema
// Source of truth for all data models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER              // full control incl. role approvals (ADMIN kept as legacy synonym)
  ADMIN
  SENIOR_DISPATCHER
  DISPATCHER
  UPDATER
  RECRUITER
  FINANCE
  CLIENT             // truck-owner company account: read-only, own company only
  DRIVER             // driver account: own trips, statuses and personal finance
}

enum UserStatus {
  ACTIVE
  PENDING            // signed up, waiting for Owner role approval
  REJECTED           // registration rejected by Owner
  INACTIVE
  SUSPENDED
}

enum ClientStatus {
  ACTIVE
  WARNING
  INACTIVE
  AT_RISK
}

// NOTE: Driver.status is intentionally a String (not this enum) so that
// admins can add/rename/disable statuses via the DriverStatusConfig
// dictionary without a schema migration. This enum is kept only as a
// reference list of the seeded system codes.
enum DriverStatus {
  AVAILABLE
  ASSIGNED
  TO_PICKUP
  AT_PICKUP
  LOADING
  ON_LOAD
  IN_TRANSIT
  AT_DELIVERY
  UNLOADING
  DELIVERED
  INACTIVE
  OFF_DUTY
  MAINTENANCE
  VACATION
  SUSPENDED
}

enum DriverStatusSource {
  CRM
  APP
  TELEGRAM
  GPS
  SYSTEM
}

enum TruckStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum LoadStatus {
  NEW_LEAD
  NEGOTIATING
  BOOKED
  RATE_CONFIRMATION_RECEIVED
  ASSIGNED
  EN_ROUTE_TO_PICKUP
  AT_PICKUP
  LOADED
  IN_TRANSIT
  AT_DELIVERY
  DELIVERED
  POD_UPLOADED
  INVOICED
  PAID
  CLOSED
  CANCELLED
  PROBLEM
}

enum InvoiceStatus {
  PENDING
  UNPAID
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  RECEIVED
  OVERDUE
}

enum DocumentType {
  RATE_CONFIRMATION
  BOL
  POD
  LUMPER_RECEIPT
  INSURANCE
  REGISTRATION
  CONTRACT
  W9
  CDL
  MC_AUTHORITY
  OTHER
}

enum DocumentEntityType {
  LOAD
  CLIENT
  DRIVER
  TRUCK
}

enum CommunicationChannel {
  RINGCENTRAL
  GMAIL
  TELEGRAM
  SMS
  INTERNAL
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum IssueType {
  DETENTION
  BREAKDOWN
  LATE_PICKUP
  LATE_DELIVERY
  WEATHER
  COMMUNICATION
  ROUTE_DEVIATION
  ACCIDENT
  OTHER
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum LocationSource {
  MANUAL
  GPS
  ELD
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskCreatedFrom {
  MISSED_CALL
  MANUAL
  AI
  SYSTEM
}

enum ExportScope {
  CLIENTS
  DRIVERS
  LOADS
  FINANCE
  ALL
}

enum ExportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FinanceEntryType {
  DISPATCH_FEE
  SENIOR_COMMISSION
  FIXED_EXPENSE
  COMPANY_REVENUE
}

enum LoadStatusSource {
  CRM
  TELEGRAM
  APP
  SYSTEM
}

enum TrailerType {
  DRY_VAN
  REEFER
  FLATBED
  STEP_DECK
  LOWBOY
  TANKER
  CONESTOGA
  OTHER
}

enum MaintenanceStatus {
  OK
  SCHEDULED
  IN_PROGRESS
  OVERDUE
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  clerkId      String     @unique
  fullName     String
  email        String     @unique
  phone        String?
  role         UserRole
  isSenior     Boolean    @default(false)
  status       UserStatus @default(ACTIVE)
  // ── Registration / role-approval flow ──
  requestedRole   UserRole?  // role the person asked for at sign-up
  roleRequestNote String?    // free-form note ("I drive for ABC Logistics, truck TRK-1004")
  approvedById    String?
  approvedBy      User?      @relation("UserApprovals", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectedReason  String?
  // ── Role bindings ──
  clientId     String?    // CLIENT accounts: which company this login belongs to
  clientAccount Client?   @relation("ClientUsers", fields: [clientId], references: [id])
  driverId     String?    // DRIVER accounts: which driver profile this login belongs to
  driverAccount Driver?   @relation("DriverUsers", fields: [driverId], references: [id])
  twoFaEnabled Boolean    @default(false)
  ndaAccepted  Boolean    @default(false)
  ndaAcceptedAt DateTime?
  ndaVersion   String?
  managerId    String?
  manager      User?      @relation("TeamHierarchy", fields: [managerId], references: [id])
  team         User[]     @relation("TeamHierarchy")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  clientsManaged      Client[]          @relation("DispatcherClients")
  driversManaged      Driver[]          @relation("DispatcherDrivers")
  driversUpdated      Driver[]          @relation("UpdaterDrivers")
  loadsDispatched     Load[]            @relation("DispatcherLoads")
  loadsUpdated        Load[]            @relation("UpdaterLoads")
  locationUpdates     LocationUpdate[]
  communications      Communication[]   @relation("CreatedByUser")
  tasks               Task[]            @relation("AssignedTasks")
  tasksCreated        Task[]            @relation("CreatedTasks")
  auditLogs           AuditLog[]
  activityLogs        ActivityLog[]
  accessLogs          AccessLog[]
  exportRequests      ExportRequest[]   @relation("RequestedBy")
  exportApprovals     ExportRequest[]   @relation("ApprovedBy")
  statusChanges       LoadStatusHistory[]
  commissions         FinanceEntry[]
  surveysReceived     Survey[]
  driverStatusChanges DriverStatusHistory[] @relation("DriverStatusChangedBy")
  driversStatusSet    Driver[]              @relation("DriverStatusUpdatedBy")
  notifications       Notification[]        @relation("UserNotifications")
  approvalsGiven      User[]                @relation("UserApprovals")

  @@index([role])
  @@index([managerId])
}

model AccessLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ip        String?
  device    String?
  loginAt   DateTime @default(now())
  logoutAt  DateTime?

  @@index([userId])
}

// ─── CLIENTS / TRUCK OWNERS ───────────────────────────────────────────────────

model Client {
  id                String       @id @default(cuid())
  companyName       String
  mc                String?      @unique
  dot               String?
  status            ClientStatus @default(ACTIVE)
  dispatchFeePercent Float       @default(10.0)
  dispatcherId      String?
  dispatcher        User?        @relation("DispatcherClients", fields: [dispatcherId], references: [id])
  address           String?
  city              String?
  state             String?
  zip               String?
  notes             String?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contacts      ClientContact[]
  trucks        Truck[]
  drivers       Driver[]
  loads         Load[]
  documents     Document[]      @relation("ClientDocuments")
  communications Communication[]
  invoices      Invoice[]
  surveys       Survey[]
  financeEntries FinanceEntry[]
  portalUser    PortalUser?
  userAccounts  User[]          @relation("ClientUsers")

  @@index([dispatcherId])
  @@index([status])
}

model ClientContact {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  email    String?
  phone    String?
  telegram String?
  role     String?
  isPrimary Boolean @default(false)

  @@index([clientId])
}

// ─── DRIVERS ─────────────────────────────────────────────────────────────────

model Driver {
  id             String       @id @default(cuid())
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  fullName       String
  phone          String?
  email          String?
  avatarUrl      String?
  telegram       String?
  telegramChatId String?
  cdlNumber      String?
  cdlState       String?
  cdlExpiry      DateTime?
  // Operational status code — FK-like reference to DriverStatusConfig.code
  // (kept as String so admins can manage the status dictionary at runtime).
  status         String       @default("AVAILABLE")
  statusUpdatedAt   DateTime?
  statusUpdatedById String?
  statusUpdatedBy   User?     @relation("DriverStatusUpdatedBy", fields: [statusUpdatedById], references: [id])
  statusComment     String?   // last dispatcher comment
  statusReason      String?   // reason for INACTIVE / MAINTENANCE / SUSPENDED / manual override
  expectedReturnAt  DateTime? // for MAINTENANCE / VACATION / SUSPENDED
  homeBase       String?
  preferredLanes String[]
  currentTruckId String?      @unique
  currentLoadId  String?
  currentLoad    Load?        @relation("DriverCurrentLoad", fields: [currentLoadId], references: [id])
  currentTrailerId String?
  currentTrailer   Trailer?   @relation("DriverCurrentTrailer", fields: [currentTrailerId], references: [id])
  // Denormalized "live" position for fast map/list reads (history in LocationUpdate)
  currentLat                Float?
  currentLng                Float?
  currentLocationLabel      String?
  currentLocationUpdatedAt  DateTime?
  currentEta                DateTime?
  dispatcherId   String?
  dispatcher     User?        @relation("DispatcherDrivers", fields: [dispatcherId], references: [id])
  updaterId      String?
  updater        User?        @relation("UpdaterDrivers", fields: [updaterId], references: [id])
  score          Float        @default(100.0)
  // Personal pay rate ($ per loaded mile) for the driver's own finance view
  payPerMile     Float?
  hosAvailableUntil DateTime?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  currentTruck    Truck?          @relation("CurrentDriver", fields: [currentTruckId], references: [id])
  loads           Load[]
  locationUpdates LocationUpdate[]
  statusHistory   DriverStatusHistory[]
  documents       Document[]      @relation("DriverDocuments")
  issues          Issue[]         @relation("DriverIssues")
  scoreEvents     ScoreEvent[]
  mobileUser      MobileUser?
  userAccounts    User[]          @relation("DriverUsers")

  @@index([clientId])
  @@index([dispatcherId])
  @@index([status])
  @@index([currentLoadId])
}

// ─── DRIVER STATUS DICTIONARY ────────────────────────────────────────────────
// Admin-editable dictionary of driver operational statuses. System rows are
// seeded and cannot be deleted (only renamed / recolored / disabled); custom
// rows can be added at runtime without any code change.

model DriverStatusConfig {
  id             String   @id @default(cuid())
  code           String   @unique // "AVAILABLE", "TO_PICKUP", custom codes...
  label          String
  color          String   @default("#4ade80") // hex used across UI + map
  icon           String?  // lucide icon name
  description    String?
  category       String   @default("OPERATIONAL") // OPERATIONAL | UNAVAILABLE
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  isSystem       Boolean  @default(false)
  requiresLoad   Boolean  @default(false)
  // Field keys that become required in the Change Status modal for this status
  requiredFields String[] @default([])
  // Allowed next status codes; empty = terminal-ish (override only)
  allowedNext    String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─── DRIVER STATUS HISTORY ───────────────────────────────────────────────────

model DriverStatusHistory {
  id                 String   @id @default(cuid())
  driverId           String
  driver             Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  previousStatus     String?
  newStatus          String
  loadId             String?
  load               Load?    @relation(fields: [loadId], references: [id])
  truckId            String?
  truck              Truck?   @relation(fields: [truckId], references: [id])
  trailerId          String?
  originAddress      String?
  originLat          Float?
  originLng          Float?
  destinationAddress String?
  destinationLat     Float?
  destinationLng     Float?
  currentLat         Float?
  currentLng         Float?
  eta                DateTime?
  comment            String?
  reason             String?
  isManualOverride   Boolean  @default(false)
  isAutomatic        Boolean  @default(false)
  source             DriverStatusSource @default(CRM)
  // Seconds spent in previousStatus (for analytics: time-in-status, utilization)
  durationSeconds    Int?
  changedById        String?
  changedBy          User?    @relation("DriverStatusChangedBy", fields: [changedById], references: [id])
  changedAt          DateTime @default(now())
  createdAt          DateTime @default(now())

  @@index([driverId, changedAt])
  @@index([loadId])
  @@index([newStatus])
  @@index([changedAt])
}

// ─── IN-APP NOTIFICATIONS ────────────────────────────────────────────────────
// CRM-internal notifications; architecture-ready for future Telegram/SMS/email/
// push delivery (a worker can fan out unread rows to external channels).

model Notification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type       String    // "driver.status.updated" | "gps.stale" | "eta.changed" | ...
  title      String
  body       String?
  entityType String?
  entityId   String?
  metadata   Json?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

// ─── TRUCKS ───────────────────────────────────────────────────────────────────

model Truck {
  id                String            @id @default(cuid())
  clientId          String
  client            Client            @relation(fields: [clientId], references: [id])
  truckNumber       String
  vin               String?
  plate             String?
  plateState        String?
  trailerType       TrailerType       @default(DRY_VAN)
  eldProvider       String?
  eldDeviceId       String?
  currentDriverId   String?
  currentLoadId     String?
  maintenanceStatus MaintenanceStatus @default(OK)
  insuranceExp      DateTime?
  registrationExp   DateTime?
  iftaExp           DateTime?
  year              Int?
  make              String?
  model             String?
  notes             String?
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  currentDriver Driver?    @relation("CurrentDriver")
  loads         Load[]
  trailers      Trailer[]
  documents     Document[] @relation("TruckDocuments")
  driverStatusHistory DriverStatusHistory[]

  @@index([clientId])
  @@index([currentDriverId])
}

model Trailer {
  id           String      @id @default(cuid())
  truckId      String?
  truck        Truck?      @relation(fields: [truckId], references: [id])
  trailerNumber String?
  type         TrailerType
  length       Int?
  year         Int?
  plate        String?
  vin          String?

  currentDrivers Driver[] @relation("DriverCurrentTrailer")
  loads          Load[]   @relation("LoadTrailer")
}

// ─── BROKERS ─────────────────────────────────────────────────────────────────

model Broker {
  id        String   @id @default(cuid())
  name      String
  mc        String?  @unique
  email     String?
  phone     String?
  rating    Float    @default(3.0)
  notes     String?
  createdAt DateTime @default(now())

  loads          Load[]
  communications Communication[]
}

// ─── LOADS ───────────────────────────────────────────────────────────────────

model Load {
  id              String        @id @default(cuid())
  loadCode        String        @unique @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  brokerId        String?
  broker          Broker?       @relation(fields: [brokerId], references: [id])
  brokerContact   String?
  brokerEmail     String?
  brokerPhone     String?
  dispatcherId    String?
  dispatcher      User?         @relation("DispatcherLoads", fields: [dispatcherId], references: [id])
  updaterId       String?
  updater         User?         @relation("UpdaterLoads", fields: [updaterId], references: [id])
  driverId        String?
  driver          Driver?       @relation(fields: [driverId], references: [id])
  truckId         String?
  truck           Truck?        @relation(fields: [truckId], references: [id])

  // Route
  pickupAddress   String?
  pickupCity      String?
  pickupState     String?
  pickupZip       String?
  pickupLat       Float?
  pickupLng       Float?
  pickupAt        DateTime?
  actualDepartureAt   DateTime? // when driver went IN_TRANSIT
  actualDeliveryAt    DateTime? // when load was DELIVERED
  estimatedArrivalAt  DateTime? // current ETA
  loadedAt            DateTime? // when loading finished (ON_LOAD)
  currentLat          Float?    // denormalized from driver GPS while active
  currentLng          Float?
  trailerId       String?
  trailer         Trailer?      @relation("LoadTrailer", fields: [trailerId], references: [id])
  deliveryAddress String?
  deliveryCity    String?
  deliveryState   String?
  deliveryZip     String?
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryAt      DateTime?

  // Financials
  rate            Float         @default(0)
  loadedMiles     Float         @default(0)
  emptyMiles      Float         @default(0)
  totalMiles      Float         @default(0)
  rpm             Float?        // Calculated: rate / totalMiles
  commodity       String?
  weight          Float?
  equipmentType   TrailerType   @default(DRY_VAN)
  lumper          Float         @default(0)
  detention       Float         @default(0)
  layover         Float         @default(0)
  tonu            Float         @default(0)

  // Status
  status          LoadStatus    @default(NEW_LEAD)
  invoiceStatus   InvoiceStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)

  notes           String?
  referenceNumber String?
  poNumber        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  statusHistory   LoadStatusHistory[]
  documents       Document[]         @relation("LoadDocuments")
  issues          Issue[]
  locationUpdates LocationUpdate[]
  communications  Communication[]
  invoices        Invoice[]
  driverStatusHistory DriverStatusHistory[]
  currentDrivers      Driver[]        @relation("DriverCurrentLoad")

  @@index([clientId])
  @@index([dispatcherId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
}

model LoadStatusHistory {
  id          String           @id @default(cuid())
  loadId      String
  load        Load             @relation(fields: [loadId], references: [id], onDelete: Cascade)
  fromStatus  LoadStatus?
  toStatus    LoadStatus
  changedById String?
  changedBy   User?            @relation(fields: [changedById], references: [id])
  source      LoadStatusSource @default(CRM)
  notes       String?
  at          DateTime         @default(now())

  @@index([loadId])
}

// ─── DOCUMENTS ───────────────────────────────────────────────────────────────

model Document {
  id           String             @id @default(cuid())
  entityType   DocumentEntityType
  entityId     String
  docType      DocumentType
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String?
  uploadedAt   DateTime           @default(now())
  status       String             @default("active")
  notes        String?

  // Polymorphic relations
  load   Load?   @relation("LoadDocuments",   fields: [entityId], references: [id], map: "load_doc")
  client Client? @relation("ClientDocuments", fields: [entityId], references: [id], map: "client_doc")
  driver Driver? @relation("DriverDocuments", fields: [entityId], references: [id], map: "driver_doc")
  truck  Truck?  @relation("TruckDocuments",  fields: [entityId], references: [id], map: "truck_doc")

  @@index([entityType, entityId])
  @@index([docType])
}

// ─── COMMUNICATIONS ───────────────────────────────────────────────────────────

model Communication {
  id              String                 @id @default(cuid())
  channel         CommunicationChannel
  direction       CommunicationDirection
  from            String?
  to              String?
  subject         String?
  body            String?
  recordingUrl    String?
  aiSummary       String?
  duration        Int?                   // seconds, for calls
  isRead          Boolean                @default(false)

  // Related context
  relatedClientId String?
  relatedClient   Client?  @relation(fields: [relatedClientId], references: [id])
  relatedLoadId   String?
  relatedLoad     Load?    @relation(fields: [relatedLoadId], references: [id])
  relatedDriverId String?
  relatedBrokerId String?
  relatedBroker   Broker?  @relation(fields: [relatedBrokerId], references: [id])

  createdById     String?
  createdBy       User?    @relation("CreatedByUser", fields: [createdById], references: [id])
  externalId      String?  // ID from RingCentral/Gmail/TG
  at              DateTime @default(now())

  tasks Task[]

  @@index([channel])
  @@index([relatedClientId])
  @@index([relatedLoadId])
  @@index([isRead])
  @@index([at])
}

// ─── TASKS ────────────────────────────────────────────────────────────────────

model Task {
  id              String          @id @default(cuid())
  title           String
  description     String?
  priority        TaskPriority    @default(MEDIUM)
  dueAt           DateTime?
  assigneeId      String?
  assignee        User?           @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById     String?
  createdBy       User?           @relation("CreatedTasks", fields: [createdById], references: [id])
  status          TaskStatus      @default(PENDING)
  createdFrom     TaskCreatedFrom @default(MANUAL)
  communicationId String?
  communication   Communication?  @relation(fields: [communicationId], references: [id])
  relatedLoadId   String?
  relatedClientId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueAt])
}

// ─── ISSUES ───────────────────────────────────────────────────────────────────

model Issue {
  id          String      @id @default(cuid())
  loadId      String
  load        Load        @relation(fields: [loadId], references: [id], onDelete: Cascade)
  driverId    String?
  driver      Driver?     @relation("DriverIssues", fields: [driverId], references: [id])
  type        IssueType
  description String
  status      IssueStatus @default(OPEN)
  createdById String?
  resolvedAt  DateTime?
  at          DateTime    @default(now())

  @@index([loadId])
  @@index([status])
}

// ─── LOCATION UPDATES ─────────────────────────────────────────────────────────

model LocationUpdate {
  id          String         @id @default(cuid())
  driverId    String
  driver      Driver         @relation(fields: [driverId], references: [id])
  loadId      String?
  load        Load?          @relation(fields: [loadId], references: [id])
  lat         Float
  lng         Float
  label       String?
  speed       Float?
  heading     Float?
  accuracy    Float?
  source      LocationSource @default(MANUAL)
  eta         DateTime?
  etaLabel    String?
  updatedById String?
  updatedBy   User?          @relation(fields: [updatedById], references: [id])
  at          DateTime       @default(now())

  @@index([driverId])
  @@index([loadId])
  @@index([at])
}

// ─── FINANCE ─────────────────────────────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  loadId      String
  load        Load          @relation(fields: [loadId], references: [id])
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  number      String        @unique
  amount      Float
  issuedAt    DateTime      @default(now())
  dueAt       DateTime?
  paidAmount  Float         @default(0)
  paidAt      DateTime?
  status      InvoiceStatus @default(PENDING)
  agingDays   Int           @default(0) // calculated field, updated by cron
  notes       String?

  @@index([clientId])
  @@index([status])
  @@index([dueAt])
}

model FinanceEntry {
  id              String           @id @default(cuid())
  period          String           // "2024-W01", "2024-01"
  type            FinanceEntryType
  clientId        String?
  client          Client?          @relation(fields: [clientId], references: [id])
  dispatcherId    String?
  dispatcher      User?            @relation(fields: [dispatcherId], references: [id])
  gross           Float            @default(0)
  amount          Float            @default(0)
  formulaSnapshot Json             // { rate, percentage, ... } at time of calculation
  notes           String?
  createdAt       DateTime         @default(now())

  @@index([period])
  @@index([type])
  @@index([dispatcherId])
}

model CompanySettings {
  id                    String   @id @default(cuid())
  companyName           String   @default("Dispatch Co.")
  companyPercentage     Float    @default(10.0)  // % of gross
  seniorCommissionRate  Float    @default(1.5)   // % of gross
  targetRpm             Float    @default(2.5)
  fixedExpenses         Float    @default(0)
  logoUrl               String?
  timezone              String   @default("America/Chicago")

  // ── Driver status automation (geofence-based suggestions / auto-changes) ──
  autoStatusEnabled           Boolean @default(false)
  autoStatusMode              String  @default("SUGGEST") // SUGGEST | AUTO
  pickupGeofenceRadiusMiles   Float   @default(1.0)
  deliveryGeofenceRadiusMiles Float   @default(1.0)
  minGeofenceMinutes          Int     @default(10)
  autoInTransitOnMove         Boolean @default(false) // auto ON_LOAD -> IN_TRANSIT when GPS moves
  gpsStaleMinutes             Int     @default(30)    // warn when no GPS for N minutes
  notifyOnStatusChange        Boolean @default(true)
  // GPS history retention (LocationUpdate cleanup); archived beyond this window
  locationRetentionDays       Int     @default(90)

  updatedAt             DateTime @updatedAt
}

// ─── SURVEYS / FEEDBACK ───────────────────────────────────────────────────────

model Survey {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  dispatcherId String?
  dispatcher   User?    @relation(fields: [dispatcherId], references: [id])
  rating       Int      // 1-5
  comment      String?
  week         String   // "2024-W01"
  at           DateTime @default(now())

  @@index([clientId])
}

// ─── DRIVER SCORE ────────────────────────────────────────────────────────────

model ScoreEvent {
  id        String   @id @default(cuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  eventType String   // "late_pickup", "on_time_delivery", "incident", etc.
  weight    Float    // positive or negative
  notes     String?
  at        DateTime @default(now())

  @@index([driverId])
}

// ─── AUDIT / SECURITY ─────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String   // "create", "update", "delete", "export", "login"
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  // { role, source: "CRM"|"APP"|"SYSTEM"|..., isAutomatic, isManualOverride, device }
  meta       Json?
  at         DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([at])
}

model ExportRequest {
  id            String       @id @default(cuid())
  requestedById String
  requestedBy   User         @relation("RequestedBy", fields: [requestedById], references: [id])
  scope         ExportScope
  reason        String?
  status        ExportStatus @default(PENDING)
  approvedById  String?
  approvedBy    User?        @relation("ApprovedBy", fields: [approvedById], references: [id])
  fileUrl       String?
  at            DateTime     @default(now())
  resolvedAt    DateTime?

  @@index([status])
  @@index([requestedById])
}

// ─── PORTAL / MOBILE USERS ───────────────────────────────────────────────────

model PortalUser {
  id           String   @id @default(cuid())
  clientId     String   @unique
  client       Client   @relation(fields: [clientId], references: [id])
  clerkId      String   @unique
  email        String   @unique
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
}

model MobileUser {
  id          String   @id @default(cuid())
  driverId    String   @unique
  driver      Driver   @relation(fields: [driverId], references: [id])
  clerkId     String   @unique
  email       String?
  phone       String?
  linkCode    String?  @unique  // one-time Telegram linking code
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
}

// ─── TELEGRAM LINK CODES ──────────────────────────────────────────────────────

model TelegramLink {
  id        String   @id @default(cuid())
  code      String   @unique
  entityId  String   // driver or client id
  entityType String  // "driver" or "client"
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── INTEGRATIONS (Dashboard card) ───────────────────────────────────────────

model Integration {
  id          String    @id @default(cuid())
  type        String    // "ringcentral" | "gmail" | "telegram" | "mapbox" | ...
  name        String
  status      String    @default("disconnected") // "connected" | "disconnected" | "error"
  isConnected Boolean   @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
}

// ─── ACTIVITY FEED (Dashboard card) ──────────────────────────────────────────
// Human-readable feed, distinct from AuditLog (which stores technical
// before/after diffs for compliance). Written alongside AuditLog at the
// same call sites, not a replacement for it.

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  entityType  String   // "Load" | "Client" | "Invoice" | "Communication" | ...
  entityId    String?
  action      String   // "created" | "status_changed" | "payment_received" | "message_received" | ...
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
